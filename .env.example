# ─────────────────────────────────────────────────────────────
# AAAI — environment variable TEMPLATE
#
# HOW TO USE:
#   1. Copy this file and rename the copy to  .env
#   2. Fill in the real values in .env
#   3. NEVER commit .env — it is already blocked in .gitignore
#
# This file is safe to commit because it contains only NAMES and
# fake values. It tells the team what to set, without sharing secrets.
# ─────────────────────────────────────────────────────────────

# --- OpenAI (the "brain": Whisper + GPT-4o-mini) ---
OPENAI_API_KEY=sk-replace-with-your-real-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1

# --- Budget guard (SRS-FR-16 / NFR-03) ---
# Hard ceiling. Also set the same cap in the OpenAI dashboard as a backstop.
MONTHLY_BUDGET_CEILING_USD=10.00

# --- PostgreSQL ---
DATABASE_URL=postgresql://username:password@localhost:5432/aaai

# --- Sessions & magic-link auth (SRS-FR-04) ---
# SECRET_KEY signs session tokens. Use a long random string, not a word.
SECRET_KEY=replace-with-a-long-random-string
MAGIC_LINK_EXPIRY_MINUTES_CANDIDATE=60
MAGIC_LINK_EXPIRY_MINUTES_RECRUITER=30

# --- Email provider for magic links (decided Week 5 — Nareach) ---
EMAIL_PROVIDER_API_KEY=replace-me
EMAIL_FROM_ADDRESS=noreply@example.com

# --- App ---
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000/api/v1
AUDIO_STORAGE_DIR=./media
